#!/bin/sh
# Regenerate PDFs from HTML before commit.

CHANGED_HTML=$(git diff --cached --name-only | grep '\.html$')

if [ -z "$CHANGED_HTML" ]; then
  exit 0
fi

CHROME="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
REPO_ROOT=$(git rev-parse --show-toplevel)

html_to_pdf() {
  local html="$1" pdf="$2"
  "$CHROME" --headless --disable-gpu --no-pdf-header-footer \
    --print-to-pdf="$pdf" "file://$html" 2>/dev/null
}

if echo "$CHANGED_HTML" | grep -q "sef-kloninger-resume\.html"; then
  echo "pre-commit: regenerating sef-kloninger-resume.pdf..."
  html_to_pdf "$REPO_ROOT/sef-kloninger-resume.html" "$REPO_ROOT/sef-kloninger-resume.pdf"
  git add sef-kloninger-resume.pdf
fi

if echo "$CHANGED_HTML" | grep -q "sef-kloninger-resume-full\.html"; then
  if [ -z "$RESUME_ADDRESS" ]; then
    echo "pre-commit: WARNING: RESUME_ADDRESS is not set; skipping sef-kloninger-resume-full.pdf" >&2
  else
    echo "pre-commit: regenerating sef-kloninger-resume-full.pdf..."
    html_to_pdf "$REPO_ROOT/sef-kloninger-resume-full.html" "$REPO_ROOT/sef-kloninger-resume-full.pdf"
    git add sef-kloninger-resume-full.pdf
  fi
fi
